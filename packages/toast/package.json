{
  "name": "@solidcn/toast",
  "version": "0.0.2",
  "type": "module",
  "description": "Dual toast system for SolidJS — standard (shadcn-style) + sileo (physics-based)",
  "keywords": ["solidjs", "toast", "notification", "physics", "animation"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidcn-ui/solidcn.git",
    "directory": "packages/toast"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./standard": {
      "types": "./dist/standard/index.d.ts",
      "import": "./dist/standard/index.js"
    },
    "./sileo": {
      "types": "./dist/sileo/index.d.ts",
      "import": "./dist/sileo/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "solid-js": ">=1.9",
    "class-variance-authority": ">=0.7"
  },
  "devDependencies": {
    "solid-js": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "vite": "^6.0.11",
    "vite-plugin-solid": "^2.11.1",
    "typescript": "^5.7.3"
  }
}

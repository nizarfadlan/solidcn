{
  "name": "@solidcn/core",
  "version": "0.0.1",
  "type": "module",
  "description": "SolidJS UI components — a port of shadcn/ui",
  "keywords": ["solidjs", "ui", "components", "shadcn", "kobalte", "tailwind"],
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@kobalte/core": ">=0.13",
    "@modular-forms/solid": ">=0.25",
    "corvu": ">=0.7",
    "solid-js": ">=1.9",
    "tailwind-variants": ">=0.3"
  },
  "devDependencies": {
    "@kobalte/core": "^0.13.10",
    "clsx": "^2.1.1",
    "lucide-solid": "^0.479.0",
    "solid-js": "^1.9.4",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-solid": "^2.11.1"
  },
  "dependencies": {
    "@modular-forms/solid": "^0.25.1",
    "corvu": "^0.7.2"
  }
}

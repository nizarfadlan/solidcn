{
  "name": "create-solidcn-app",
  "version": "0.0.1",
  "type": "module",
  "description": "Create a new SolidJS app with solidcn pre-configured",
  "keywords": ["solidjs", "create-app", "starter", "template"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/solidcn-ui/solidcn",
    "directory": "packages/create-solidcn-app"
  },
  "main": "./dist/index.js",
  "bin": {
    "create-solidcn-app": "./dist/index.js"
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
